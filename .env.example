# Unie Cortex — copy to .env
UNIE_CORTEX_ENV=development

# Network intelligence (parcel zone mocks, LTL mock, scenario compare) — see docs/NETWORK_INTELLIGENCE.md
# NETWORK_INTELLIGENCE_ENABLED=true
# Complementary multi-node audit on POST .../audit-synthesis (cached rate-shop batch; see docs/NETWORK_INTELLIGENCE.md)
# AUDIT_COMPLEMENTARY_NETWORK_ENABLED=true

# --- Persistence (pick one) ---
# Option A — MongoDB (recommended if the rest of your stack is on Mongo)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=unie_cortex
# When MONGODB_URI is set, SQLite/Postgres below are ignored for Cortex data.

# Option B — SQLite (local dev, no Mongo)
# DATABASE_URL=sqlite+aiosqlite:///./unie_cortex.db

# Option C — Postgres (when you add it later)
# DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/unie_cortex

# Integrations (also used automatically by MAIW integration agent)
# Location: Geoapify is tried first if set; else Mapbox; else Nominatim
# GEOAPIFY_API_KEY=
# GEOCODING_MAPBOX_TOKEN=pk....

# Rates: Shippo takes priority if SHIPPO_API_KEY is set (label spine + /v1/integrations/rate-quote)
# SHIPPO_API_KEY=shippo_test_...
# SHIPPO_MOCK_MODE=false
#   true  = no Shippo HTTP calls; deterministic fake multi-carrier rates (safe for CI)
#   false = live Shippo rate quotes (still test keys until you go live)

# Optional custom rate API (used only if Shippo is not configured)
# RATE_SHOPPING_URL=https://your-rates/v1/quote
# RATE_SHOPPING_API_KEY=...
# RATE_SHOP_CACHE_TTL_DAYS=30   # Cached parcel quotes per physical bucket + lane (SQLite/Mongo)

# Sales tax (TaxJar summary_rates → tax_jurisdiction_snapshots; monthly POST /v1/integrations/tax/sync)
# TAXJAR_API_KEY=
# TAX_SYNC_MOCK_MODE=false   # true = sync writes deterministic 51 US stubs without TaxJar (CI / local)

# Keepa (Amazon) — POST /v1/integrations/keepa/product { "asin": "B0...", "domain": 1, "sku": "optional" }
# KEEPA_API_KEY=
# KEEPA_TTL_DAYS=30   # Reuse full product JSON without calling Keepa again until expiry
# KEEPA_PRODUCT_OFFERS=20   # Keepa product() offers= — buy-box / competition context (0 = omit param)
# KEEPA_PRODUCT_STATS_DAYS=90   # Keepa product() stats= window (0 = omit param)
# Seller-scoped monthly planning (Keepa monthlySold is ASIN-wide; caps/slice tune suggested units)
# KEEPA_PLANNING_MONTHLY_CAP_3P=400
# KEEPA_PLANNING_LARGE_VELOCITY_THRESHOLD=800
# KEEPA_PLANNING_BUYBOX_WINNER_CAP=1200
# KEEPA_BUYBOX_HISTORY_WINDOW_DAYS=30
# KEEPA_PLANNING_BUYBOX_HISTORY_KNOWN_CAP=50000
# KEEPA_PLANNING_BUYBOX_FOLLOWER_SIMILARITY_WEIGHT=0.18
# Item intelligence: mock parcel grid per warehouse before allocation (needs warehouse postal or lat/lon)
# PLACEMENT_MOCK_DESTINATIONS_PER_WAREHOUSE=48
# PLACEMENT_MOCK_MIDPOINT_TIE_BAND=0.07
# SKU / item intelligence (physical-twin inheritance + demand extract)
# SKU_INHERIT_MIN_LABEL_LINES=12
# PHYSICAL_SIGNATURE_WEIGHT_STEP_LB=0.5
# PHYSICAL_SIGNATURE_DIM_STEP_IN=1.0
# Item intelligence: hub-first inbound + cross-dock + spoke receive (default). Set blended_legacy for simple blended receiving only.
# ECONOMICS_INBOUND_FLOW_MODEL=blended_legacy
# ECONOMICS_DEFAULT_PRICING_PROFILE_ID=profile_nj_v1
# Item intelligence: tri-modal multi-DC block (original input + baseline heuristic + NVIDIA cuOpt when configured)
# ITEM_INTELLIGENCE_CUOPT_OVERVIEW_ENABLED=true
# ITEM_INTELLIGENCE_NVIDIA_CUOPT_ENABLED=true

# Address validation (Google preferred)
# GOOGLE_MAPS_API_KEY=   # Enable "Address Validation API" on this key in Google Cloud Console
# GOOGLE_ADDRESS_VALIDATION_USPS_CASS=true   # US/PR: include USPS CASS data in response

# Or custom validator proxy instead of Google:
# ADDRESS_VALIDATION_URL=https://your-validator/validate
# ADDRESS_VALIDATION_API_KEY=...

# Warehouse Intelligence (/v1 pick-pathing, labor, uniewms, …): force original+internal only (skip NVIDIA variant branches)
# MAIW_FORCE_INTERNAL_ONLY=false

# MAIW + narrative: same NVIDIA Integrate API key
# NVIDIA_API_KEY=nvapi-...
# NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
# CUOPT_NIM_URL=https://your-cuopt/v1   # Optional: custom service that exposes POST {url}/optimize (warehouses+lanes JSON)
# CUOPT_API_KEY=nvapi-...   # Bearer for NVIDIA cuOpt cloud (optimize.api.nvidia.com) or custom NIM
# MULTI_DC_CUOPT_CLOUD_ENABLED=false   # true = POST /v1/assessment/multi-dc-preview uses optimize.api.nvidia.com (same as your invoke_url + NVCF poll)
# NVIDIA_CUOPT_CLOUD_INVOKE_URL=https://optimize.api.nvidia.com/v1/nvidia/cuopt
# NVIDIA_CUOPT_CLOUD_STATUS_URL_PREFIX=https://optimize.api.nvidia.com/v1/status/
# NVIDIA_CUOPT_CLOUD_POLL_INTERVAL_SECONDS=1
# NVIDIA_CUOPT_CLOUD_POLL_TIMEOUT_SECONDS=300
# TMS_NVIDIA_CUOPT_CLOUD_ENABLED=false   # Append NVIDIA cuOpt cloud alternative in route_variants
# TMS_NVIDIA_CUOPT_MAX_NODES=25
# TMS_NVIDIA_CUOPT_TIME_LIMIT_SECONDS=30
# TMS_NVIDIA_CUOPT_POLL_CAP_SECONDS=120
# TMS_NIM_DISPATCH_SUMMARY_ENABLED=false   # Sync NIM summary on propose_routes (needs NVIDIA_API_KEY)
